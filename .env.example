# ============================================================
#  Copy this file to ".env" and edit. NEVER commit .env.
# ============================================================

# --- Database (consumed by the compose "db" service) ---
POSTGRES_USER=smartmoney
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=smartmoney

# --- Database URL (consumed by the app; host "db" = compose service) ---
DATABASE_URL=postgresql://smartmoney:change-me-to-a-strong-secret@db:5432/smartmoney

# --- App ---
TZ=Asia/Kolkata
LOG_LEVEL=INFO
INSTRUMENTS=NIFTY,BANKNIFTY
POLL_INTERVAL_SEC=60
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
TOKEN_REFRESH_IST=08:45

# --- Broker ---
# "mock" = synthetic data, no credentials needed (use this first to verify the pipeline).
# "dhan" = real chain via app/providers/dhan.py (wire it, then switch).
BROKER=mock
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
